# ── Server ──────────────────────────────────────────────────
PORT=5000
NODE_ENV=development          # development | production

# ── MongoDB ─────────────────────────────────────────────────
# Get from MongoDB Atlas → Connect → Drivers
MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ── JWT ─────────────────────────────────────────────────────
JWT_SECRET=your_super_secret_key_min_32_chars
JWT_EXPIRE=7d

# ── Stripe (Test Keys) ───────────────────────────────────────
# Get from https://dashboard.stripe.com/test/apikeys
STRIPE_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxx
STRIPE_PUBLISHABLE_KEY=pk_test_xxxxxxxxxxxxxxxxxxxx
# Get from Stripe Dashboard → Webhooks → Add endpoint
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ── Email (Nodemailer) ───────────────────────────────────────
# For Gmail: enable 2FA → App Passwords → generate one
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_16_char_app_password
EMAIL_FROM=Golf Charity <your_email@gmail.com>

# ── Admin Seed ───────────────────────────────────────────────
ADMIN_EMAIL=admin@golfcharity.com
ADMIN_PASSWORD=admin123

# ── Frontend ─────────────────────────────────────────────────
FRONTEND_URL=http://localhost:3000
